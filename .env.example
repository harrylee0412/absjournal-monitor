# 环境变量示例 (复制为 .env 并填入真实值)

# Neon PostgreSQL 连接 (Pooler - 给 Prisma Client 用)
DATABASE_URL="postgresql://username:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Neon PostgreSQL 直连 (给 Prisma Migrate 用)
DIRECT_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# CrossRef API 联系邮箱 (可选但推荐)
CROSSREF_CONTACT_EMAIL="your-email@example.com"

# CrossRef 请求超时（毫秒）
CROSSREF_HTTP_TIMEOUT_MS=25000

# CrossRef 请求失败重试次数（不含首次请求）
CROSSREF_MAX_RETRIES=2

# CrossRef 重试基础退避时间（毫秒）
CROSSREF_RETRY_BASE_MS=800

# 单期刊总处理超时（毫秒）
JOURNAL_PROCESS_TIMEOUT_MS=120000

# 更新流心跳间隔（毫秒）
UPDATE_HEARTBEAT_MS=3000

# 单次 /api/check-updates 请求软超时（毫秒）
UPDATE_REQUEST_SOFT_TIMEOUT_MS=55000

# 软超时保留缓冲（毫秒）
UPDATE_REQUEST_RESERVE_MS=4000

# 启动单期刊处理所需最小预算（毫秒）
MIN_JOURNAL_BUDGET_MS=7000
